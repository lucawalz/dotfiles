#!/usr/bin/env lua

-- Build the SbarLua module on first run (fresh machine bootstrap)
os.execute("[ -f \"$HOME/.local/share/sketchybar_lua/sketchybar.so\" ] || (git clone https://github.com/FelixKratz/SbarLua.git /tmp/SbarLua && cd /tmp/SbarLua && make install && rm -rf /tmp/SbarLua)")

-- Locate the compiled SbarLua module and this config's lua files
package.cpath = package.cpath .. ";" .. os.getenv("HOME") .. "/.local/share/sketchybar_lua/?.so"
package.path = package.path .. ";" .. os.getenv("CONFIG_DIR") .. "/?.lua"

sbar = require("sketchybar")

-- Bundle the whole initial config into one message for a fast startup
sbar.begin_config()
require("bar")
require("default")
require("init")
sbar.hotload(true)
sbar.end_config()

-- Drop the bar in from above on launch
sbar.bar({ y_offset = -40 })
sbar.animate("sin", 25, function()
  sbar.bar({ y_offset = 6 })
end)

-- Keep the process alive so subscribe() callbacks fire
sbar.event_loop()
