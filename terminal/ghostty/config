# By default Reload config with shft + cmd + ,
theme = Dark Modern
background-opacity = 0.75
background-blur-radius = 23

font-family = JetBrainsMonoNL Nerd Font 
font-size = 15
cursor-style = block
cursor-style-blink = false
cursor-invert-fg-bg = true

macos-titlebar-style = hidden
macos-option-as-alt = true
mouse-hide-while-typing = true

confirm-close-surface = false
window-decoration = auto
window-padding-x = 10
window-padding-y = 0
window-padding-balance = false

auto-update = check
auto-update-channel = stable

# extras
shell-integration-features = no-cursor 
copy-on-select = clipboard

# Custom Keybinds (super = Cmd on macOS)
# Single-press binds following macOS conventions

# Utility
keybind = super+i=inspector:toggle
keybind = super+shift+r=reload_config
keybind = super+grave_accent=toggle_quick_terminal

# Window/Tab management (macOS standard)
keybind = super+t=new_tab
keybind = super+w=close_surface
keybind = super+n=new_window

# Tab nav (standard Cmd+Number)
keybind = super+1=goto_tab:1
keybind = super+2=goto_tab:2
keybind = super+3=goto_tab:3
keybind = super+4=goto_tab:4
keybind = super+5=goto_tab:5
keybind = super+6=goto_tab:6
keybind = super+7=goto_tab:7
keybind = super+8=goto_tab:8
keybind = super+9=goto_tab:9

# Splitting
keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down
keybind = super+shift+e=equalize_splits

# Split nav (Cmd+hjkl - matches Neovim hjkl pattern)
keybind = super+h=goto_split:left
keybind = super+j=goto_split:down
keybind = super+k=goto_split:up
keybind = super+l=goto_split:right

#Shaders
custom-shader = shaders/bettercrt.glsl
custom-shader = shaders/retro-terminal.glsl

#Window 
# Dimensions (rows/cols)
window-height = 41
window-width = 149

# Remembers the window position so it stays centered
window-save-state = always
